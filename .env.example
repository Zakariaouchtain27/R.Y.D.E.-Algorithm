# ── Flight API credentials ──────────────────────────────────────────
DUFFEL_API_KEY=
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# ── Stripe (payments) ───────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# ── App config ──────────────────────────────────────────────────────
# Admin dashboard password — change this before going live
RYDE_ADMIN_SECRET=change-me-before-production

# Public URL of your deployment
BASE_URL=http://localhost:8000

# ── Security ──────────────────────────────────────────────────────────
# Secret used to sign webhook payloads sent to agency endpoints.
# Agencies verify the X-RYDE-Signature header with this value.
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
RYDE_WEBHOOK_SECRET=

# ── Database ────────────────────────────────────────────────────────
# Local dev: leave as default.
# Railway production: set to /data/ryde.db and mount a Volume at /data.
# If DATABASE_URL is set (Railway Postgres), SQLite is not used.
RYDE_DB_PATH=ryde.db
DATABASE_URL=

# ── Bot config ──────────────────────────────────────────────────────
POLL_INTERVAL_MINUTES=60
MARKET_TICK_SECONDS=3
SUCCESS_FEE_PERCENT=20
