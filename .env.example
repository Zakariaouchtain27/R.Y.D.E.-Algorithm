# ── Duffel API (full booking lifecycle: search, hold, book, cancel) ──────────
# Sign up at https://app.duffel.com/join
# Use duffel_test_... keys for sandbox, duffel_live_... for production
DUFFEL_API_KEY=duffel_test_your_key_here

# ── Amadeus for Developers (price monitoring only) ────────────────────────────
# Sign up at https://developers.amadeus.com
# Free tier: 2,000 calls/month on the test environment
AMADEUS_CLIENT_ID=your_amadeus_client_id
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret

# ── Bot configuration ─────────────────────────────────────────────────────────
# How often to poll prices (minutes)
POLL_INTERVAL_MINUTES=60

# SQLite database path (swap for postgres:// URL + SQLAlchemy in production)
RYDE_DB_PATH=ryde.db

# Decision thresholds (0-100). Raise to be more conservative.
STRIKE_THRESHOLD=72
PHANTOM_HOLD_THRESHOLD=48
