# ── Flight API credentials ──────────────────────────────────────────
DUFFEL_API_KEY=
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# ── Stripe (consumer payments) ─────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# ── LemonSqueezy (B2B agency subscriptions) ─────────────────────────
# 1. Sign up at lemonsqueezy.com (no company needed — they are merchant of record)
# 2. Create two products: Starter ($49/mo) and Pro ($149/mo)
# 3. In each product's Settings > Checkout, set redirect URL to:
#    https://your-domain.railway.app/welcome?order={order_id}
# 4. Copy the checkout URLs and paste below
# 5. In Settings > Webhooks, point to https://your-domain.railway.app/webhook/lemonsqueeze
#    and copy the signing secret into LEMONSQUEEZE_WEBHOOK_SECRET
LEMONSQUEEZE_WEBHOOK_SECRET=
LS_STARTER_URL=
LS_PRO_URL=

# ── App config ──────────────────────────────────────────────────────
RYDE_ADMIN_SECRET=change-me-before-production
BASE_URL=http://localhost:8000

# ── Security ──────────────────────────────────────────────────────────
# Webhook signing secret for payloads sent TO agencies
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
RYDE_WEBHOOK_SECRET=

# ── Database ────────────────────────────────────────────────────────
# Local dev: leave as default.
# Railway: set DATABASE_URL (auto-injected by Railway Postgres add-on)
RYDE_DB_PATH=ryde.db
DATABASE_URL=

# ── Bot config ──────────────────────────────────────────────────────
POLL_INTERVAL_MINUTES=60
MARKET_TICK_SECONDS=3
SUCCESS_FEE_PERCENT=20
LOG_LEVEL=INFO
